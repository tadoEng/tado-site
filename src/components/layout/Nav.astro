---
// src/components/layout/Nav.astro
import { Button } from "@/components/starwind/button";
import { ThemeToggle } from "@/components/starwind/theme-toggle";
import { Sheet, SheetTrigger, SheetContent } from "@/components/starwind/sheet";
import { Separator } from "@/components/starwind/separator";

const navLinks = [
  { href: "/",          label: "Home"     },
  { href: "/writing",   label: "Writing"  },
  { href: "/projects",  label: "Projects" },
  { href: "/tools",     label: "Tools"    },
  { href: "/about",     label: "About"    },
];

const pathname = Astro.url.pathname;

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<!-- Stress-map gradient bar — FEA contour signature -->
<div class="stress-bar" aria-hidden="true"></div>

<header
  id="site-nav"
  class="sticky top-0.75 z-50 w-full border-b bg-background/90 backdrop-blur-md
         transition-transform duration-300 ease-in-out"
>
  <div class="mx-auto flex max-w-layout items-center justify-between px-6 h-14">

    <!-- ── Logo ──────────────────────────────────────────── -->
    <a
      href="/"
      class="flex items-center gap-1.5 font-bold text-sm tracking-tight"
      aria-label="Home"
    >
      <span class="text-primary" aria-hidden="true">✦</span>
      <span>Tado</span>
    </a>

    <!-- ── Desktop nav ───────────────────────────────────── -->
    <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
      {navLinks.map(({ href, label }) => (
        <Button
          href={href}
          variant={isActive(href) ? "secondary" : "ghost"}
          size="sm"
        >
          {label}
        </Button>
      ))}
    </nav>

    <!-- ── Right side: theme toggle + mobile menu ────────── -->
    <div class="flex items-center gap-2">
      <ThemeToggle />

      <Sheet>
        <SheetTrigger>
          <Button variant="ghost" size="icon" class="md:hidden" aria-label="Open menu">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <line x1="2" y1="4.5"  x2="16" y2="4.5"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="2" y1="9"    x2="16" y2="9"    stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="2" y1="13.5" x2="16" y2="13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </Button>
        </SheetTrigger>

        <SheetContent side="right" class="w-64">
          <nav class="flex flex-col gap-1 mt-6" aria-label="Mobile navigation">
            {navLinks.map(({ href, label }) => (
              <Button
                href={href}
                variant={isActive(href) ? "secondary" : "ghost"}
                class="justify-start"
              >
                {label}
              </Button>
            ))}
            <Separator class="my-3" />
            <div class="flex items-center gap-2 px-2 text-sm text-muted-foreground">
              <span>Theme</span>
              <ThemeToggle />
            </div>
          </nav>
        </SheetContent>
      </Sheet>
    </div>

  </div>
</header>

<script>
  (() => {
    const nav = document.getElementById("site-nav");
    if (!nav) return;

    // Heights
    const STRESS_BAR_H = 3;   // px — .stress-bar
    const NAV_H = 56;          // px — h-14 = 56px
    const GAP = 16;            // breathing room below nav

    // --toc-top when nav is visible: bar(3) + nav(56) + gap(16) = 75px ≈ 4.7rem
    const TOC_TOP_VISIBLE  = `${STRESS_BAR_H + NAV_H + GAP}px`;
    // --toc-top when nav is hidden: just bar(3) + gap(8)
    const TOC_TOP_HIDDEN   = `${STRESS_BAR_H + 8}px`;

    let lastScroll = window.scrollY;
    let hidden = false;
    let ticking = false;

    function setNavState(hide: boolean) {
      if (hide === hidden) return;
      hidden = hide;

      if (hide) {
        // Slide nav up by its own height (hide below stress bar)
        nav!.style.transform = `translateY(-${NAV_H + 1}px)`;
        document.documentElement.style.setProperty("--toc-top", TOC_TOP_HIDDEN);
      } else {
        nav!.style.transform = "translateY(0)";
        document.documentElement.style.setProperty("--toc-top", TOC_TOP_VISIBLE);
      }
    }

    // Initialise TOC offset
    document.documentElement.style.setProperty("--toc-top", TOC_TOP_VISIBLE);

    function onScroll() {
      const current = window.scrollY;
      const delta = current - lastScroll;

      // Don't hide nav when near the top of the page
      if (current < NAV_H * 2) {
        setNavState(false);
      } else if (delta > 4) {
        // Scrolling DOWN — hide nav
        setNavState(true);
      } else if (delta < -4) {
        // Scrolling UP — show nav
        setNavState(false);
      }

      lastScroll = current;
      ticking = false;
    }

    window.addEventListener("scroll", () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(onScroll);
    }, { passive: true });
  })();
</script>