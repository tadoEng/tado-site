---
// src/components/ui/ToolCard.astro
import { Badge } from "@/components/starwind/badge";

interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;          // emoji or single char
  status?: "live" | "beta" | "soon";
}

const {
  title,
  description,
  href,
  icon = "⌇",
  status = "live",
} = Astro.props;
---

<a
  href={href}
  class="group relative flex flex-col gap-3 rounded-lg border bg-card p-5
         shadow-sm overflow-hidden no-underline
         transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md
         hover:border-primary/40"
>
  <!-- Animated bottom accent line -->
  <div
    class="absolute bottom-0 left-0 h-0.5 w-0 bg-primary
           transition-all duration-300 group-hover:w-full"
    aria-hidden="true"
  ></div>

  <!-- Icon -->
  <div
    class="flex h-9 w-9 items-center justify-center rounded-md border
           bg-primary/10 text-primary text-base"
    aria-hidden="true"
  >
    {icon}
  </div>

  <!-- Title + status -->
  <div class="flex items-start justify-between gap-2">
    <h3 class="font-semibold text-sm text-foreground group-hover:text-primary transition-colors">
      {title}
    </h3>
    <Badge
      variant={status === "live" ? "success" : status === "beta" ? "warning" : "secondary"}
      class="text-[10px] px-1.5 py-0 shrink-0"
    >
      {status}
    </Badge>
  </div>

  <!-- Description -->
  <p class="text-xs text-muted-foreground leading-relaxed">
    {description}
  </p>

  <!-- CTA hint -->
  <span class="text-[11px] text-primary font-medium mt-auto">
    Open tool →
  </span>
</a>
