---
// src/components/ui/TableOfContents.astro
// Right-side sticky TOC for article and project pages.
// Highlights the current section as the user scrolls,
// scrolls the active link into view inside the panel,
// and re-initialises correctly on Astro view transitions.

interface Heading {
  depth: number;
  slug:  string;
  text:  string;
}
interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{filtered.length > 1 && (
  <div class="toc-outer">
    <nav id="toc" aria-label="Table of contents" class="toc-inner no-scrollbar">

      <p class="toc-header">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M1 3h10M1 6h7M1 9h9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        On this page
      </p>

      <ol class="toc-list">
        {filtered.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              class:list={["toc-link", h.depth === 3 && "toc-link-sub"]}
              data-heading={h.slug}
            >
              <span class="toc-pill" aria-hidden="true"></span>
              <span class="toc-text">{h.text}</span>
            </a>
          </li>
        ))}
      </ol>

      <div class="toc-progress" aria-hidden="true">
        <div class="toc-progress-track">
          <div id="toc-progress-bar" class="toc-progress-bar"></div>
        </div>
        <span id="toc-progress-pct" class="toc-progress-pct">0%</span>
      </div>

    </nav>
  </div>
)}

<script>
  (() => {
    let teardown: (() => void) | null = null;

    // ── initToc ───────────────────────────────────────────────
    // Called once on first load and again on every Astro page
    // transition so the TOC always matches the current article.
    function initToc() {
      teardown?.();
      teardown = null;

      const toc = document.getElementById("toc");
      if (!toc) return;

      const links = Array.from(
        toc.querySelectorAll<HTMLAnchorElement>("[data-heading]")
      );
      if (!links.length) return;

      const headingEls = links
        .map((l) => document.getElementById(l.dataset.heading!))
        .filter((el): el is HTMLElement => el !== null);

      if (!headingEls.length) return;

      const progressBar = document.getElementById("toc-progress-bar");
      const progressPct = document.getElementById("toc-progress-pct");
      const headingIds = headingEls.map((el) => el.id);
      const visibleIds = new Set<string>();

      // Track the currently highlighted link so we don't thrash the DOM
      // Start with a sentinel that won't match any real heading id so the
      // first setActive() call always fires even when activeId === "".
      let currentActive: string | null = null;

      function setActive(id: string) {
        if (id === currentActive) return;
        currentActive = id;

        links.forEach((link) => {
          const isActive = link.dataset.heading === id;
          link.classList.toggle("active", isActive);
        });

        // Keep active link visible inside the TOC scroller only.
        // Avoid element.scrollIntoView here because it can scroll the page
        // viewport in some cases.
        const activeLink = toc!.querySelector<HTMLElement>(".toc-link.active");
        const outer = toc!.closest<HTMLElement>(".toc-outer");
        if (!activeLink || !outer) return;

        const padding = 20;
        const linkTop = activeLink.offsetTop;
        const linkBottom = linkTop + activeLink.offsetHeight;
        const viewTop = outer.scrollTop;
        const viewBottom = viewTop + outer.clientHeight;

        if (linkTop < viewTop + padding) {
          outer.scrollTo({
            top: Math.max(0, linkTop - padding),
            behavior: "smooth",
          });
        } else if (linkBottom > viewBottom - padding) {
          outer.scrollTo({
            top: linkBottom - outer.clientHeight + padding,
            behavior: "smooth",
          });
        }
      }

      // Read the CSS variable that Nav.astro maintains so the offset
      // always matches the current nav visibility state.
      function getNavOffset(): number {
        const raw = getComputedStyle(document.documentElement)
          .getPropertyValue("--toc-top")
          .trim();
        if (!raw) return 75;
        if (raw.endsWith("px")) return parseFloat(raw);
        if (raw.endsWith("rem")) return parseFloat(raw) * 16;
        return 75;
      }

      function pickByTopOffset(offset: number): string {
        let activeId = "";
        for (const el of headingEls) {
          if (el.getBoundingClientRect().top - offset <= 0) {
            activeId = el.id;
          } else {
            break;
          }
        }
        return activeId || headingEls[0]?.id || "";
      }

      function pickFirstVisible(): string {
        return headingIds.find((id) => visibleIds.has(id)) ?? "";
      }

      let observer: IntersectionObserver | null = null;
      let observerOffset = -1;

      function buildObserver() {
        observer?.disconnect();
        visibleIds.clear();

        observerOffset = getNavOffset() + 10;
        observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              const id = (entry.target as HTMLElement).id;
              if (!id) continue;

              if (entry.isIntersecting && entry.intersectionRatio > 0) {
                visibleIds.add(id);
              } else {
                visibleIds.delete(id);
              }
            }

            const active = pickFirstVisible() || pickByTopOffset(observerOffset);
            setActive(active);
          },
          {
            // Same pattern as Maxime Heckel's scrollspy: use rootMargin
            // to account for a sticky header and create a top "active zone".
            root: null,
            rootMargin: `-${observerOffset}px 0px -65% 0px`,
            threshold: [0, 1],
          }
        );

        headingEls.forEach((el) => observer?.observe(el));
      }

      function onScroll() {
        const offset = getNavOffset() + 10;

        if (visibleIds.size === 0) {
          setActive(pickByTopOffset(offset));
        } else {
          setActive(pickFirstVisible());
        }

        // If nav visibility changed, rebuild rootMargin so active detection
        // stays aligned with the nav offset.
        if (Math.abs(offset - observerOffset) > 1) {
          buildObserver();
        }

        // ── Reading progress bar ──────────────────────────────
        if (progressBar && progressPct) {
          const doc   = document.documentElement;
          const total = doc.scrollHeight - doc.clientHeight;
          const pct   = total > 0 ? Math.round((doc.scrollTop / total) * 100) : 0;
          progressBar.style.width  = pct + "%";
          progressPct.textContent  = pct + "%";
        }
      }

      // ── Smooth-scroll on link click ───────────────────────
      const clickCleanup: Array<() => void> = [];
      links.forEach((link) => {
        const clickHandler = (e: MouseEvent) => {
          e.preventDefault();
          const id = link.dataset.heading!;
          const target = document.getElementById(id);
          if (!target) return;

          const offset = getNavOffset() + 4;
          const y = target.getBoundingClientRect().top + window.scrollY - offset;
          window.scrollTo({ top: y, behavior: "smooth" });
          history.pushState(null, "", `#${id}`);
          setActive(id); // optimistic — feels snappier than waiting for scroll event
        };

        link.addEventListener("click", clickHandler);
        clickCleanup.push(() => link.removeEventListener("click", clickHandler));
      });

      // ── Reveal the panel (opacity transition in toc.css) ─
      toc.classList.add("is-ready");

      buildObserver();
      onScroll();

      // ── Scroll listener ───────────────────────────────────
      let ticking = false;
      const scrollHandler = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          onScroll();
          ticking = false;
        });
      };
      const hashHandler = () => {
        const id = decodeURIComponent(window.location.hash.replace(/^#/, ""));
        if (id && headingIds.includes(id)) {
          setActive(id);
        }
      };

      window.addEventListener("scroll", scrollHandler, { passive: true });
      window.addEventListener("resize", onScroll, { passive: true });
      window.addEventListener("hashchange", hashHandler, { passive: true });

      // ── Cleanup on next transition ─────────────────────────
      // Astro fires astro:before-swap before tearing down the old page.
      // Remove listeners/observer to avoid memory leaks.
      const cleanup = () => {
        observer?.disconnect();
        observer = null;
        visibleIds.clear();
        clickCleanup.forEach((fn) => fn());
        clickCleanup.length = 0;
        window.removeEventListener("scroll", scrollHandler);
        window.removeEventListener("resize", onScroll);
        window.removeEventListener("hashchange", hashHandler);
      };
      teardown = cleanup;

      document.addEventListener(
        "astro:before-swap",
        () => {
          cleanup();
          teardown = null;
        },
        { once: true }
      );
    }

    // ── Bootstrap ─────────────────────────────────────────────
    // astro:page-load fires after every navigation (including first load)
    // when View Transitions are enabled. It's safe to listen even when
    // View Transitions are disabled — the event still fires once on load.
    document.addEventListener("astro:page-load", initToc);

    // Belt-and-suspenders: also run via DOMContentLoaded for setups
    // where astro:page-load may fire before this script parses.
    if (document.readyState !== "loading") {
      initToc();
    } else {
      document.addEventListener("DOMContentLoaded", () => initToc(), { once: true });
    }
  })();
</script>
