---
// src/components/ui/TableOfContents.astro

interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{filtered.length > 1 && (
  <div class="toc-outer">
    <nav id="toc" aria-label="Table of contents" class="toc-inner no-scrollbar">

      <!-- Header label -->
      <p class="toc-header">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M1 3h10M1 6h7M1 9h9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        On this page
      </p>

      <!-- Links -->
      <ol class="toc-list">
        {filtered.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              class:list={["toc-link", h.depth === 3 && "toc-link-sub"]}
              data-heading={h.slug}
            >
              <span class="toc-pill" aria-hidden="true"></span>
              <span class="toc-text">{h.text}</span>
            </a>
          </li>
        ))}
      </ol>

      <!-- Page progress -->
      <div class="toc-progress" aria-hidden="true">
        <div class="toc-progress-track">
          <div id="toc-progress-bar" class="toc-progress-bar"></div>
        </div>
        <span id="toc-progress-pct" class="toc-progress-pct">0%</span>
      </div>

    </nav>
  </div>
)}

<script>
  (() => {
    const toc = document.getElementById("toc");
    if (!toc) return;

    const links = Array.from(toc.querySelectorAll<HTMLAnchorElement>("[data-heading]"));
    if (!links.length) return;

    const headingEls = links
      .map((l) => document.getElementById(l.dataset.heading!))
      .filter((el): el is HTMLElement => el !== null);

    const progressBar = document.getElementById("toc-progress-bar");
    const progressPct = document.getElementById("toc-progress-pct");

    // ── Active link ────────────────────────────────────────────
    let currentActive = "";

    function setActive(id: string) {
      if (id === currentActive) return;
      currentActive = id;
      links.forEach((link) => {
        link.classList.toggle("active", link.dataset.heading === id);
      });
    }

    // ── Scroll handler ─────────────────────────────────────────
    const NAV_OFFSET = 88; // px — matches sticky nav height + buffer

    function onScroll() {
      // Active heading: last one whose top has passed the offset
      let activeId = headingEls[0]?.id ?? "";
      for (const el of headingEls) {
        if (el.getBoundingClientRect().top - NAV_OFFSET <= 0) {
          activeId = el.id;
        } else {
          break;
        }
      }
      setActive(activeId);

      // Progress bar
      if (progressBar && progressPct) {
        const doc = document.documentElement;
        const total = doc.scrollHeight - doc.clientHeight;
        const pct = total > 0 ? Math.round((doc.scrollTop / total) * 100) : 0;
        progressBar.style.width = pct + "%";
        progressPct.textContent = pct + "%";
      }
    }

    // ── Smooth scroll on click ─────────────────────────────────
    links.forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const id = link.dataset.heading!;
        const target = document.getElementById(id);
        if (!target) return;
        const y = target.getBoundingClientRect().top + window.scrollY - NAV_OFFSET + 4;
        window.scrollTo({ top: y, behavior: "smooth" });
        history.pushState(null, "", `#${id}`);
      });
    });

    // ── Init ───────────────────────────────────────────────────
    onScroll();

    let ticking = false;
    window.addEventListener("scroll", () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => { onScroll(); ticking = false; });
    }, { passive: true });

    window.addEventListener("resize", onScroll, { passive: true });
  })();
</script>