---
// src/components/ui/TableOfContents.astro
// ─────────────────────────────────────────────────────────────
// JetBrains-style sticky TOC:
//   - Always visible as user scrolls the article
//   - Active heading highlighted with accent bar
//   - Smooth scroll-spy with requestAnimationFrame
//   - Section progress mini-indicator
// ─────────────────────────────────────────────────────────────

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{filtered.length > 1 && (
  <nav
    id="toc"
    aria-label="Table of contents"
    class="toc-container no-scrollbar"
  >
    <!-- Header -->
    <div class="toc-header">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="shrink-0 opacity-50">
        <path d="M1 3h10M1 6h7M1 9h9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      <span>On this page</span>
    </div>

    <!-- Links -->
    <ol class="toc-list" role="list">
      {filtered.map((h) => (
        <li role="listitem">
          <a
            href={`#${h.slug}`}
            class={`toc-link ${h.depth === 3 ? "toc-link-sub" : "toc-link-h2"}`}
            data-heading={h.slug}
          >
            {h.depth === 3 && (
              <span class="toc-sub-indicator" aria-hidden="true" />
            )}
            <span class="toc-link-text">{h.text}</span>
          </a>
        </li>
      ))}
    </ol>

    <!-- Reading progress within article -->
    <div class="toc-progress-wrap" aria-hidden="true">
      <div class="toc-progress-track">
        <div id="toc-progress-fill" class="toc-progress-fill" />
      </div>
      <span id="toc-progress-label" class="toc-progress-label">0%</span>
    </div>
  </nav>
)}

<script>
  const toc = document.getElementById("toc");
  if (!toc) throw new Error();

  const links = Array.from(toc.querySelectorAll<HTMLAnchorElement>(".toc-link"));
  const headingEls = links
    .map((l) => document.getElementById(l.dataset.heading ?? ""))
    .filter(Boolean) as HTMLElement[];

  const fill = document.getElementById("toc-progress-fill");
  const label = document.getElementById("toc-progress-label");

  if (links.length === 0 || headingEls.length === 0) throw new Error();

  // ── Active tracking ──────────────────────────────────────
  const setActive = (id: string) => {
    links.forEach((link) => {
      const isActive = link.dataset.heading === id;
      link.classList.toggle("active", isActive);
    });
  };

  const OFFSET = 120;

  const updateActive = () => {
    let activeId = headingEls[0].id;
    for (const heading of headingEls) {
      if (heading.getBoundingClientRect().top - OFFSET <= 0) {
        activeId = heading.id;
      } else break;
    }
    setActive(activeId);

    // Update progress
    if (fill && label) {
      const el = document.documentElement;
      const pct = el.scrollHeight > el.clientHeight
        ? Math.round((el.scrollTop / (el.scrollHeight - el.clientHeight)) * 100)
        : 0;
      fill.style.width = pct + "%";
      label.textContent = pct + "%";
    }
  };

  let ticking = false;
  const onScroll = () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => { updateActive(); ticking = false; });
  };

  updateActive();
  window.addEventListener("scroll", onScroll, { passive: true });
  window.addEventListener("resize", onScroll);

  // ── Smooth scroll with offset ─────────────────────────────
  links.forEach((link) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      const id = link.dataset.heading;
      if (!id) return;
      const target = document.getElementById(id);
      if (!target) return;
      const top = target.getBoundingClientRect().top + window.scrollY - OFFSET + 8;
      window.scrollTo({ top, behavior: "smooth" });
      // Update URL without jumping
      history.pushState(null, "", `#${id}`);
    });
  });
</script>