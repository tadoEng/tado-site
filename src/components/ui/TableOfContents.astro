---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{filtered.length > 1 && (
  <nav id="toc" aria-label="Table of contents"
    class="sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto no-scrollbar">
    <p class="font-mono text-[10px] uppercase tracking-widest text-muted-foreground mb-3">
      On this page
    </p>
    <ol class="flex flex-col gap-0.5">
      {filtered.map((h) => (
        <li>
          <a
            href={`#${h.slug}`}
            class={`toc-link block text-muted-foreground hover:text-foreground transition-colors py-0.5 ${h.depth === 3 ? "pl-3 text-xs" : "text-sm"}`}
            data-heading={h.slug}
          >
            {h.text}
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>(".toc-link");
  if (links.length > 0) {
    const headingIds = Array.from(links).map((l) => l.dataset.heading!);
    const headingEls = headingIds
      .map((id) => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const link = document.querySelector<HTMLAnchorElement>(
            `.toc-link[data-heading="${entry.target.id}"]`
          );
          if (!link) return;
          if (entry.isIntersecting) {
            links.forEach((l) => l.classList.remove("active"));
            link.classList.add("active");
          }
        });
      },
      { rootMargin: "-80px 0px -60% 0px", threshold: 0 }
    );

    headingEls.forEach((el) => observer.observe(el));
  }
</script>
