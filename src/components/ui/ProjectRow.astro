---
// src/components/ui/ProjectRow.astro
import { Badge } from "@/components/starwind/badge";
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
  index: number;
}

const { project, index } = Astro.props;
const { title, description, stack, status, liveUrl, githubUrl } = project.data;

const statusVariant = {
  live:     "success",
  wip:      "warning",
  archived: "secondary",
} as const;
---

<a
  href={`/projects/${project.id}`}
  class="group grid grid-cols-[3rem_1fr_auto] items-start gap-4
         rounded-lg px-3 py-4 border border-transparent
         transition-all duration-150
         hover:bg-card hover:border-border hover:shadow-sm
         no-underline"
>
  <!-- Number -->
  <span class="font-mono text-xs text-muted-foreground pt-0.5 select-none">
    {String(index + 1).padStart(2, "0")}
  </span>

  <!-- Info -->
  <div class="flex flex-col gap-1.5">
    <div class="flex items-center gap-2 flex-wrap">
      <h3 class="font-semibold text-sm text-foreground group-hover:text-primary transition-colors">
        {title}
      </h3>
      <Badge variant={statusVariant[status]} class="text-[10px] px-1.5 py-0">
        {status}
      </Badge>
    </div>
    <p class="text-xs text-muted-foreground">
      {description}
    </p>
    <!-- Stack chips -->
    <div class="flex flex-wrap gap-1 mt-0.5">
      {stack.map((tech) => (
        <Badge variant="outline" class="text-[10px] px-1.5 py-0 font-mono">
          {tech}
        </Badge>
      ))}
    </div>
  </div>

  <!-- Arrow -->
  <span
    class="text-muted-foreground text-base pt-0.5 transition-transform duration-200
           group-hover:translate-x-1 group-hover:text-primary"
    aria-hidden="true"
  >
    →
  </span>
</a>
