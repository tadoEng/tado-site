---
// src/components/ui/InlineTOC.astro
// Inline "In this article" box — JetBrains blog style
// Placed at the TOP of article content, above the first heading.
// Only renders when there are 3+ headings.

interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{filtered.length >= 3 && (
  <nav class="inline-toc" aria-label="In this article" id="inline-toc">
    <button
      class="inline-toc__toggle"
      aria-expanded="true"
      aria-controls="inline-toc-list"
      id="inline-toc-btn"
    >
      <span class="inline-toc__title">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="inline-toc__icon">
          <path d="M1.5 3.5h11M1.5 7h8M1.5 10.5h9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        In this article
      </span>
      <svg class="inline-toc__chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <ol class="inline-toc__list" id="inline-toc-list" role="list">
      {filtered.map((h, i) => (
        <li class:list={["inline-toc__item", h.depth === 3 && "inline-toc__item--sub"]}>
          <a href={`#${h.slug}`} class="inline-toc__link">
            {h.depth === 2 && (
              <span class="inline-toc__num" aria-hidden="true">{filtered.filter(x => x.depth === 2).indexOf(h) + 1}</span>
            )}
            {h.depth === 3 && (
              <span class="inline-toc__dot" aria-hidden="true"></span>
            )}
            <span>{h.text}</span>
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}

<script>
  (() => {
    const btn = document.getElementById("inline-toc-btn");
    const list = document.getElementById("inline-toc-list");
    if (!btn || !list) return;

    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", String(!expanded));
      list.classList.toggle("is-collapsed", expanded);
    });

    // Smooth-scroll override to respect nav offset
    document.querySelectorAll<HTMLAnchorElement>(".inline-toc__link").forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const href = link.getAttribute("href");
        if (!href) return;
        const target = document.querySelector(href);
        if (!target) return;
        const raw = getComputedStyle(document.documentElement)
          .getPropertyValue("--toc-top").trim();
        const offset = raw.endsWith("px") ? parseFloat(raw) : parseFloat(raw) * 16 || 88;
        const y = (target as HTMLElement).getBoundingClientRect().top + window.scrollY - offset - 4;
        window.scrollTo({ top: y, behavior: "smooth" });
        history.pushState(null, "", href);
      });
    });
  })();
</script>