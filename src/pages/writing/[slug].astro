---
// src/pages/writing/[slug].astro
//
// WHY slug NOT id:
// In Astro's legacy content collections (Astro 4 without the new
// content layer flag), post.id includes the file extension:
//   post.id   = "etabssharp-c-wrapper.mdx"   ← gives /writing/etabssharp-c-wrapper.mdx
//   post.slug = "etabssharp-c-wrapper"        ← gives /writing/etabssharp-c-wrapper  ✓
//
// We use post.slug for the route param and all internal hrefs.
import ArticleLayout from "@layouts/ArticleLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("writing", (p) => !p.data.draft);
  const sorted = posts.sort(
    (a, b) => a.data.publishDate.valueOf() - b.data.publishDate.valueOf()
  );

  return sorted.map((post, index) => ({
    // Route param is slug (no extension)
    params: { slug: post.slug },
    props: {
      post,
      prevPost: index > 0 ? sorted[index - 1] : undefined,
      nextPost: index < sorted.length - 1 ? sorted[index + 1] : undefined,
      // Recommend by lane first, then recency — exclude self, take top 2
      recommendedPosts: posts
        .filter((candidate) => candidate.slug !== post.slug)
        .sort((a, b) => {
          const laneMatchA = a.data.lane === post.data.lane ? 1 : 0;
          const laneMatchB = b.data.lane === post.data.lane ? 1 : 0;
          if (laneMatchA !== laneMatchB) return laneMatchB - laneMatchA;
          return b.data.publishDate.valueOf() - a.data.publishDate.valueOf();
        })
        .slice(0, 2),
    },
  }));
}

const { post, prevPost, nextPost, recommendedPosts } = Astro.props;
const { Content, headings } = await render(post);
---

<ArticleLayout
  post={post}
  headings={headings}
  prevPost={prevPost}
  nextPost={nextPost}
  recommendedPosts={recommendedPosts}
>
  <Content />
</ArticleLayout>