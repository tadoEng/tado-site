---
// src/pages/writing/index.astro
import BaseLayout from "@layouts/BaseLayout.astro";
import PostCard from "@components/ui/PostCard.astro";
import { Button } from "@/components/starwind/button";
import { getCollection } from "astro:content";

const allPosts = await getCollection("writing", (p) => !p.data.draft);
const sorted = allPosts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

// Lane filter from URL param
const url = new URL(Astro.request.url);
const activeLane = url.searchParams.get("lane") ?? "all";

const filtered =
  activeLane === "all"
    ? sorted
    : sorted.filter((p) => p.data.lane === activeLane);

const lanes = [
  { id: "all",        label: "All"        },
  { id: "structural", label: "Structural" },
  { id: "dev",        label: "Dev"        },
  { id: "tool",       label: "Tools"      },
  { id: "workflow",   label: "Workflow"   },
];
---

<BaseLayout
  title="Writing"
  description="Articles on computational structural engineering, FEM, application development, and the tools I build."
>
  <div class="mx-auto max-w-layout px-6 py-16">

    <div class="mb-10">
      <h1 class="text-3xl font-black tracking-tight mb-2">Writing</h1>
      <p class="text-muted-foreground">
        {sorted.length} posts on structural engineering, FEM, and app development.
      </p>
    </div>

    <!-- Filter tabs -->
    <nav class="flex flex-wrap gap-2 mb-10" aria-label="Filter posts by lane">
      {lanes.map(({ id, label }) => (
        <Button
          href={id === "all" ? "/writing" : `/writing?lane=${id}`}
          variant={activeLane === id ? "default" : "outline"}
          size="sm"
        >
          {label}
        </Button>
      ))}
    </nav>

    <!-- Post grid -->
    {filtered.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {filtered.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    ) : (
      <p class="text-muted-foreground text-center py-20">
        No posts in this lane yet — check back soon.
      </p>
    )}
  </div>
</BaseLayout>