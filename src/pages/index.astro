---
// src/pages/index.astro
import BaseLayout from "@layouts/BaseLayout.astro";
import PostCard from "@components/ui/PostCard.astro";
import ProjectRow from "@components/ui/ProjectRow.astro";
import ToolCard from "@components/ui/ToolCard.astro";
import HeroVisual from "@components/home/HeroVisual";
import { Button } from "@/components/starwind/button";
import { Badge } from "@/components/starwind/badge";
import { Separator } from "@/components/starwind/separator";
import { getCollection } from "astro:content";

// ── Fetch content ─────────────────────────────────────────────
const allPosts = await getCollection("writing", (p) => !p.data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const featuredPost = sortedPosts.find((p) => p.data.featured) ?? sortedPosts[0];
// PostCard uses post.slug internally, but filter here uses slug too for consistency
const gridPosts = sortedPosts
  .filter((p) => p.slug !== featuredPost?.slug)
  .slice(0, 3);

const allProjects = await getCollection("projects");
const sortedProjects = allProjects
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<BaseLayout>
  <!-- ── HERO ────────────────────────────────────────────────── -->
  <section class="relative min-h-svh flex items-center overflow-hidden border-b">
    <div
      class="absolute top-0 right-0 w-2/3 h-full pointer-events-none"
      style="background: radial-gradient(ellipse at 70% 40%, hsl(var(--primary) / 0.05) 0%, transparent 60%)"
      aria-hidden="true"
    ></div>

    <div class="mx-auto max-w-layout px-6 grid md:grid-cols-2 gap-12 items-center py-24 w-full">
      <div class="flex flex-col gap-6">
        <div class="flex items-center gap-2">
          <div class="w-6 h-px bg-primary opacity-60"></div>
          <span class="font-mono text-[11px] uppercase tracking-widest text-primary">
            Structural Engineer &amp; App Developer
          </span>
        </div>

        <h1 class="text-4xl sm:text-5xl font-black tracking-tight leading-[1.08]">
          Building tools where<br />
          <em class="not-italic text-primary">structures meet software</em>
        </h1>

        <p class="text-muted-foreground leading-relaxed max-w-md">
          I write about computational structural engineering, finite element methods,
          and the applications I build to make structural analysis more accessible,
          visual, and open.
        </p>

        <div class="flex flex-wrap gap-3">
          <Button href="/writing" size="lg">Read the blog →</Button>
          <Button href="/projects" variant="outline" size="lg">View projects</Button>
        </div>

        <div class="flex flex-wrap items-center gap-2 pt-2">
          <span class="font-mono text-[10px] uppercase tracking-wider text-muted-foreground">
            Built with
          </span>
          {["Python", "FEM", "C#", "TypeScript", "React", "Astro"].map((tech) => (
            <Badge variant="secondary" class="text-[11px] font-mono px-2 py-0.5">
              {tech}
            </Badge>
          ))}
        </div>
      </div>

      <div class="hidden md:block">
        <HeroVisual client:load />
      </div>
    </div>

    <div
      class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1
             font-mono text-[10px] uppercase tracking-widest text-muted-foreground animate-bounce"
      aria-hidden="true"
    >
      scroll
      <svg width="10" height="14" viewBox="0 0 10 14" fill="none">
        <path d="M5 0v10M1 7l4 5 4-5" stroke="currentColor" strokeWidth="1.2" strokeLinecap="round" strokeLinejoin="round"/>
      </svg>
    </div>
  </section>

  <!-- ── WRITING ──────────────────────────────────────────────── -->
  <section class="border-b py-20">
    <div class="mx-auto max-w-layout px-6">
      <div class="flex items-end justify-between mb-8">
        <div>
          <p class="font-mono text-[11px] uppercase tracking-widest text-muted-foreground mb-1">
            Latest writing
          </p>
          <h2 class="text-2xl font-bold tracking-tight">From the notebook</h2>
        </div>
        <Button href="/writing" variant="ghost" size="sm">All posts →</Button>
      </div>

      {featuredPost && (
        <a
          href={`/writing/${featuredPost.slug}`}
          class="group grid md:grid-cols-2 gap-0 rounded-xl overflow-hidden border
                 shadow-sm mb-6 transition-all duration-200 hover:shadow-md
                 hover:border-primary/30 no-underline bg-card"
        >
          <div class="bg-muted border-r min-h-[200px] flex items-center justify-center p-8">
            <div class="font-mono text-xs text-muted-foreground text-center opacity-60 space-y-1">
              <div class="text-2xl text-primary opacity-40">[ K ]{ "·" }{ "{u}" } = { "{F}" }</div>
              <div>Element stiffness equation</div>
            </div>
          </div>
          <div class="p-8 flex flex-col justify-center gap-3">
            <div class="flex items-center gap-2 flex-wrap">
              <Badge variant="warning" class="text-[11px]">{featuredPost.data.lane}</Badge>
              <span class="font-mono text-xs text-muted-foreground">
                {new Date(featuredPost.data.publishDate).toLocaleDateString("en-US", {
                  month: "short", day: "numeric", year: "numeric"
                })}
              </span>
            </div>
            <h3 class="text-xl font-bold leading-snug group-hover:text-primary transition-colors">
              {featuredPost.data.title}
            </h3>
            <p class="text-sm text-muted-foreground leading-relaxed">
              {featuredPost.data.description}
            </p>
            <span class="text-sm font-semibold text-primary mt-1">Read article →</span>
          </div>
        </a>
      )}

      {gridPosts.length > 0 && (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {gridPosts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ── PROJECTS ─────────────────────────────────────────────── -->
  <section class="border-b py-20">
    <div class="mx-auto max-w-layout px-6">
      <div class="flex items-end justify-between mb-6">
        <div>
          <p class="font-mono text-[11px] uppercase tracking-widest text-muted-foreground mb-1">
            Selected work
          </p>
          <h2 class="text-2xl font-bold tracking-tight">Projects</h2>
        </div>
        <Button href="/projects" variant="ghost" size="sm">All projects →</Button>
      </div>

      <Separator class="mb-2" />
      <div class="flex flex-col divide-y">
        {sortedProjects.map((project, i) => (
          <ProjectRow project={project} index={i} />
        ))}
      </div>
    </div>
  </section>

  <!-- ── TOOLS ────────────────────────────────────────────────── -->
  <section class="border-b py-20">
    <div class="mx-auto max-w-layout px-6">
      <div class="flex items-end justify-between mb-8">
        <div>
          <p class="font-mono text-[11px] uppercase tracking-widest text-muted-foreground mb-1">
            Open tools
          </p>
          <h2 class="text-2xl font-bold tracking-tight">Engineering calculators</h2>
        </div>
        <Button href="/tools" variant="ghost" size="sm">All tools →</Button>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <ToolCard
          title="Beam Calculator"
          description="Simply supported, fixed-end, cantilever. Shear, moment, and deflection diagrams — live as you type."
          href="/tools/beam-calculator"
          icon="⌇"
          status="live"
        />
        <ToolCard
          title="Section Properties"
          description="I, A, Z, S, r for standard and custom cross-sections. Export results to JSON."
          href="/tools/section-properties"
          icon="◎"
          status="beta"
        />
        <ToolCard
          title="Column Buckling"
          description="Euler and Johnson curves with automatic method selection based on slenderness ratio."
          href="/tools/column-buckling"
          icon="↑"
          status="soon"
        />
      </div>
    </div>
  </section>

  <!-- ── ABOUT STRIP ───────────────────────────────────────────── -->
  <section class="py-20">
    <div class="mx-auto max-w-layout px-6">
      <div class="grid md:grid-cols-[1fr_1.6fr] gap-12 items-start">
        <div>
          <p class="font-mono text-[11px] uppercase tracking-widest text-muted-foreground mb-2">About</p>
          <h2 class="text-3xl font-black tracking-tight leading-tight">tado</h2>
          <p class="font-mono text-xs text-primary mt-1 uppercase tracking-wide">
            Structural Eng. &amp; App Developer
          </p>
        </div>
        <div class="flex flex-col gap-4">
          <p class="text-muted-foreground leading-relaxed">
            I'm a structural engineer who writes software. I work on high-rise buildings
            and long-span structures, and I build the tools I wish existed — browser-based
            calculators, ETABS automations, open structural solvers.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            This site documents that work. The writing spans FEM theory, computational methods,
            and the software architecture behind the tools.
          </p>
          <div class="flex flex-wrap gap-2 pt-2">
            <Button href="/about" variant="outline" size="sm">More about me →</Button>
            <Button href="https://github.com/tadoEng" variant="ghost" size="sm" target="_blank" rel="noopener">
              GitHub
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>