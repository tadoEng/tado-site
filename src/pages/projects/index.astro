---
// src/pages/projects/index.astro
import BaseLayout from "@layouts/BaseLayout.astro";
import { Badge } from "@/components/starwind/badge";
import { Separator } from "@/components/starwind/separator";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const sorted = projects.sort((a, b) => a.data.order - b.data.order);

const statusVariant: Record<string, "success" | "warning" | "secondary"> = {
  live:     "success",
  wip:      "warning",
  archived: "secondary",
};
---

<BaseLayout
  title="Projects"
  description="Open-source tools and engineering applications I've built."
>
  <div class="mx-auto max-w-layout px-6 py-16">

    <div class="mb-12">
      <h1 class="text-3xl font-black tracking-tight mb-2">Projects</h1>
      <p class="text-muted-foreground max-w-xl">
        Open-source tools and applications at the intersection of structural
        engineering and software development.
      </p>
    </div>

    <Separator class="mb-4" />

    <div class="flex flex-col divide-y">
      {sorted.map((project, i) => (
        <a
          href={`/projects/${project.slug}`}
          class="group grid grid-cols-[3rem_1fr_auto] items-start gap-4
                 py-5 transition-all hover:bg-card hover:px-3 hover:rounded-lg no-underline"
        >
          <span class="font-mono text-xs text-muted-foreground pt-1 select-none">
            {String(i + 1).padStart(2, "0")}
          </span>

          <div class="flex flex-col gap-1.5">
            <div class="flex flex-wrap items-center gap-2">
              <h2 class="font-bold text-base text-foreground group-hover:text-primary transition-colors">
                {project.data.title}
              </h2>
              <Badge
                variant={statusVariant[project.data.status]}
                class="text-[10px] px-1.5 py-0"
              >
                {project.data.status}
              </Badge>
            </div>
            <p class="text-sm text-muted-foreground">{project.data.description}</p>
            <div class="flex flex-wrap gap-1 mt-1">
              {project.data.stack.map((tech: string) => (
                <Badge variant="outline" class="text-[10px] px-1.5 py-0 font-mono">
                  {tech}
                </Badge>
              ))}
            </div>
          </div>

          <span
            class="text-muted-foreground text-base pt-0.5 transition-transform
                   group-hover:translate-x-1 group-hover:text-primary"
            aria-hidden="true"
          >
            →
          </span>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>