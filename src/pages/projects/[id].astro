---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Badge } from "@/components/starwind/badge";
import { Button } from "@/components/starwind/button";
import { Separator } from "@/components/starwind/separator";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { title, description, stack, status, liveUrl, githubUrl } = project.data;
const { Content } = await render(project);

const statusVariant = {
  live:     "success",
  wip:      "warning",
  archived: "secondary",
} as const;
---

<BaseLayout title={title} description={description}>
  <div class="mx-auto max-w-article px-6 py-16">

    <Button href="/projects" variant="ghost" size="sm" class="mb-8 -ml-2">
      ← All projects
    </Button>

    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-3 mb-3">
        <h1 class="text-3xl font-black tracking-tight">{title}</h1>
        <Badge variant={statusVariant[status]}>{status}</Badge>
      </div>
      <p class="text-muted-foreground text-lg leading-relaxed">{description}</p>

      <div class="flex flex-wrap gap-1.5 mt-4">
        {stack.map((tech) => (
          <Badge variant="secondary" class="font-mono text-xs">{tech}</Badge>
        ))}
      </div>

      {(liveUrl || githubUrl) && (
        <div class="flex flex-wrap gap-2 mt-5">
          {liveUrl && (
            <Button href={liveUrl} target="_blank" rel="noopener" size="sm">Live demo ↗</Button>
          )}
          {githubUrl && (
            <Button href={githubUrl} variant="outline" target="_blank" rel="noopener" size="sm">GitHub ↗</Button>
          )}
        </div>
      )}
    </header>

    <Separator class="mb-8" />

    <div class="article-prose prose prose-neutral dark:prose-invert max-w-none
                prose-a:text-primary prose-a:no-underline hover:prose-a:underline">
      <Content />
    </div>

  </div>
</BaseLayout>

<script>
  async function copyText(text) {
    try {
      await navigator.clipboard.writeText(text);
      return true;
    } catch {
      const ta = document.createElement("textarea");
      ta.value = text;
      ta.setAttribute("readonly", "");
      ta.style.position = "fixed";
      ta.style.left = "-9999px";
      document.body.appendChild(ta);
      ta.select();
      const ok = document.execCommand("copy");
      ta.remove();
      return ok;
    }
  }

  function enhanceCodeBlocks() {
    const blocks = document.querySelectorAll("article .article-prose pre, .article-prose pre");
    blocks.forEach((pre) => {
      if (pre.parentElement?.classList.contains("code-block-wrap")) return;

      const code = pre.querySelector("code");
      const raw = (code?.textContent ?? pre.textContent ?? "").replace(/\n$/, "");
      const languageClass = [...(code?.classList ?? [])].find((c) => c.startsWith("language-"));
      const language = (languageClass ? languageClass.replace("language-", "") : "text")
        .replace(/[-_]/g, " ");

      const wrap = document.createElement("div");
      wrap.className = "code-block-wrap";

      const toolbar = document.createElement("div");
      toolbar.className = "code-block-toolbar";

      const lang = document.createElement("span");
      lang.className = "code-block-lang";
      lang.textContent = language;

      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "code-copy-btn";
      btn.textContent = "Copy";
      btn.setAttribute("aria-label", `Copy ${language} code`);

      btn.addEventListener("click", async () => {
        const ok = await copyText(raw);
        btn.textContent = ok ? "Copied" : "Copy failed";
        btn.classList.toggle("copied", ok);
        setTimeout(() => {
          btn.textContent = "Copy";
          btn.classList.remove("copied");
        }, 1400);
      });

      toolbar.append(lang, btn);
      pre.parentElement?.insertBefore(wrap, pre);
      wrap.append(toolbar, pre);
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", enhanceCodeBlocks, { once: true });
  } else {
    enhanceCodeBlocks();
  }
</script>
