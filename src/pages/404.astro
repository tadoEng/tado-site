---
// src/pages/404.astro
import BaseLayout from "@layouts/BaseLayout.astro";
import { Button } from "@/components/starwind/button";
---

<BaseLayout title="404 — Not Found">
  <div class="mx-auto max-w-layout px-6 py-32 text-center">
    <p class="font-mono text-6xl font-black text-primary mb-4">404</p>
    <h1 class="text-2xl font-bold mb-2">Page not found</h1>
    <p class="text-muted-foreground mb-8 max-w-sm mx-auto">
      This URL doesn't resolve to a valid node.
      Check your input and try again.
    </p>
    <Button href="/">Back to home</Button>
  </div>
</BaseLayout>
